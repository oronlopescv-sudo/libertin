# ===== OBRIGATÓRIAS =====
# Database
DATABASE_URL="postgresql://user:password@localhost:5432/rencontres_premium"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-here"

# Stripe (use sk_test_xxx para testes)
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test_..."

# Node
NODE_ENV="development"

# ===== OPCIONAIS =====
# Google OAuth (deixa vazio se não tiver)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SendGrid (deixa vazio se não tiver)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@example.com"

# Admin
ADMIN_EMAIL="admin@example.com"

